---
import { url } from '@lib/url.ts';
import { getStats } from '@lib/content.ts';
const stats = getStats();
---

<dialog class="palette" data-palette data-index-url={url('search-index.json')} aria-label="Search">
  <div class="p-head">
    <svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <circle cx="7" cy="7" r="4.5"></circle>
      <path d="M10.5 10.5 14 14" stroke-linecap="round"></path>
    </svg>
    {/* Deliberately type=text: a search input swallows the first Escape to clear
        itself, which would stop Escape from closing the dialog. */}
    <input
      type="text"
      data-palette-input
      placeholder={`Search ${stats.questions.toLocaleString()} questions, ${stats.categories} categories…`}
      autocomplete="off"
      spellcheck="false"
      aria-label="Search questions"
    />
    <kbd class="mono">ESC</kbd>
  </div>

  <div class="p-body" data-palette-results tabindex="-1">
    <p class="p-hint">Type to search across every question bank.</p>
  </div>

  <div class="p-foot">
    <span><kbd class="mono">↑</kbd><kbd class="mono">↓</kbd> navigate</span>
    <span><kbd class="mono">↵</kbd> open</span>
    <span class="grow"></span>
    <span class="mono muted">{stats.questions.toLocaleString()} questions indexed</span>
  </div>
</dialog>

<style>
  .palette {
    width: min(640px, calc(100vw - 28px));
    max-height: min(560px, calc(100dvh - 100px));
    padding: 0;
    margin: 12vh auto auto;
    border: 1px solid var(--border-strong);
    border-radius: var(--r-xl);
    background: var(--bg-elev);
    color: var(--text);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    display: none;
    flex-direction: column;
  }
  .palette[open] {
    display: flex;
  }
  .palette::backdrop {
    background: rgba(4, 5, 8, 0.66);
    backdrop-filter: blur(3px);
  }

  .p-head {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 0 14px;
    height: 54px;
    border-bottom: 1px solid var(--border);
    color: var(--text-faint);
    flex: none;
  }
  .p-head input {
    flex: 1;
    min-width: 0;
    background: none;
    border: 0;
    outline: none;
    color: var(--text);
    font-family: var(--font-body);
    font-size: var(--step-1);
  }
  .p-head input::placeholder {
    color: var(--text-faint);
  }
  .p-head input::-webkit-search-cancel-button {
    display: none;
  }

  .p-body {
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 8px;
    flex: 1;
  }
  .p-body:focus {
    outline: none;
  }

  .p-hint,
  .p-empty {
    color: var(--text-faint);
    font-size: var(--step--1);
    text-align: center;
    padding: 36px 10px;
    margin: 0;
  }

  .p-foot {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 9px 14px;
    border-top: 1px solid var(--border);
    background: var(--surface);
    font-size: 11px;
    color: var(--text-faint);
    flex: none;
  }
  .grow {
    flex: 1;
  }
  .muted {
    color: var(--text-faint);
  }

  kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 5px;
    margin-right: 2px;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--surface-2);
    color: var(--text-faint);
  }
</style>

<style is:global>
  .p-group {
    margin: 6px 0 2px;
    padding: 6px 10px 4px;
  }

  .p-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 11px;
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--text-dim);
    cursor: pointer;
  }
  .p-item:hover,
  .p-item[aria-selected='true'] {
    background: var(--accent-dim);
    color: var(--text);
  }
  .p-item[aria-selected='true'] {
    box-shadow: inset 0 0 0 1px var(--accent-line);
  }

  .p-item .p-text {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: var(--step-0);
  }
  .p-item mark {
    background: none;
    color: var(--accent-hi);
    font-weight: 600;
  }
  .p-item .p-crumb {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-faint);
    white-space: nowrap;
    flex: none;
  }
  .p-item .p-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: none;
  }
  .p-dot-e {
    background: var(--easy);
  }
  .p-dot-m {
    background: var(--medium);
  }
  .p-dot-h {
    background: var(--hard);
  }
  .p-dot-n {
    background: var(--text-faint);
  }
</style>

<script>
  import { fetchJson } from '@lib/fetch-json.ts';

  type Cat = [string, string, string, string, string];
  type Q = [string, number, string];
  type Page = [string, string, string];
  interface Index {
    cats: Cat[];
    q: Q[];
    pages: Page[];
  }

  // The palette is re-rendered on every navigation, so its elements are re-queried per
  // page. The fetched index lives in module scope and is downloaded once per session,
  // not once per page. The global ⌘K/"/" handler binds once and reaches the *current*
  // palette through these two refs, so it never points at a discarded dialog.
  let index: Index | null = null;
  let loading: Promise<Index> | null = null;
  let liveDialog: HTMLDialogElement | null = null;
  let openPalette: () => void = () => {};
  let keysBound = false;

  const init = () => {
    const dialog = document.querySelector<HTMLDialogElement>('[data-palette]');
    const input = document.querySelector<HTMLInputElement>('[data-palette-input]');
    const results = document.querySelector<HTMLDivElement>('[data-palette-results]');
    liveDialog = dialog;
    openPalette = () => {};
    if (!dialog || !input || !results) return;

    let items: HTMLElement[] = [];
    let cursor = 0;

    const loadIndex = () => {
      if (index) return Promise.resolve(index);
      if (!loading) {
        loading = fetchJson<Index>(dialog.dataset.indexUrl!)
          .then((d) => (index = d))
          // Don't cache a rejection — a failed load would poison every later search.
          .catch((e) => {
            loading = null;
            throw e;
          });
      }
      return loading;
    };

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);

    const highlight = (text: string, tokens: string[]) => {
      let out = escapeHtml(text);
      for (const tk of tokens) {
        if (!tk) continue;
        const re = new RegExp(`(${tk.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'ig');
        out = out.replace(re, '<mark>$1</mark>');
      }
      return out;
    };

    const scoreOne = (text: string, token: string) => {
      const t = text.toLowerCase();
      const i = t.indexOf(token);
      if (i === -1) return -1;
      let s = 60 - Math.min(i, 40);
      if (i === 0) s += 50;
      else if (/[^a-z0-9]/.test(t[i - 1])) s += 26;
      return s;
    };

    const scoreAll = (text: string, tokens: string[]) => {
      let total = 0;
      for (const tk of tokens) {
        const s = scoreOne(text, tk);
        if (s < 0) return -1;
        total += s;
      }
      return total - Math.min(text.length / 12, 14);
    };

    const render = (query: string) => {
      const tokens = query.toLowerCase().trim().split(/\s+/).filter(Boolean);
      if (!index || !tokens.length) {
        results.innerHTML = '<p class="p-hint">Type to search across every question bank.</p>';
        items = [];
        return;
      }

      const qAll = index.q
        .map((row) => ({ row, s: scoreAll(row[0], tokens) }))
        .filter((h) => h.s >= 0)
        .sort((a, b) => b.s - a.s);
      const qHits = qAll.slice(0, 30);

      const cHits = index.cats
        .map((row) => ({ row, s: scoreAll(`${row[2]} ${row[3]}`, tokens) }))
        .filter((h) => h.s >= 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 5);

      const pHits = index.pages
        .map((row) => ({ row, s: scoreAll(row[0], tokens) }))
        .filter((h) => h.s >= 0)
        .sort((a, b) => b.s - a.s)
        .slice(0, 5);

      if (!qAll.length && !cHits.length && !pHits.length) {
        results.innerHTML = `<p class="p-empty">No matches for “${escapeHtml(query)}”.</p>`;
        items = [];
        return;
      }

      const html: string[] = [];
      const group = (label: string, n: number) =>
        html.push(`<p class="eyebrow p-group">${label} <span class="mono">${n}</span></p>`);

      if (qHits.length) {
        // Show the true match count, not the number we chose to render.
        group('Questions', qAll.length);
        for (const { row } of qHits) {
          const cat = index.cats[row[1] as number];
          html.push(
            `<a class="p-item" href="${cat[4]}" role="option"><span class="p-dot p-dot-${row[2]}"></span>` +
              `<span class="p-text">${highlight(row[0] as string, tokens)}</span>` +
              `<span class="p-crumb">${escapeHtml(cat[3])} / ${escapeHtml(cat[2])}</span></a>`,
          );
        }
      }
      if (cHits.length) {
        group('Categories', cHits.length);
        for (const { row } of cHits) {
          html.push(
            `<a class="p-item" href="${row[4]}" role="option"><span class="p-dot p-dot-n"></span>` +
              `<span class="p-text">${highlight(row[2], tokens)}</span>` +
              `<span class="p-crumb">${escapeHtml(row[3])}</span></a>`,
          );
        }
      }
      if (pHits.length) {
        group('Pages', pHits.length);
        for (const { row } of pHits) {
          html.push(
            `<a class="p-item" href="${row[1]}" role="option"><span class="p-dot p-dot-n"></span>` +
              `<span class="p-text">${highlight(row[0], tokens)}</span>` +
              `<span class="p-crumb">${escapeHtml(row[2])}</span></a>`,
          );
        }
      }

      results.innerHTML = html.join('');
      items = [...results.querySelectorAll<HTMLElement>('.p-item')];
      cursor = 0;
      select(0);
    };

    const select = (i: number) => {
      if (!items.length) return;
      cursor = (i + items.length) % items.length;
      items.forEach((el, n) => el.setAttribute('aria-selected', String(n === cursor)));
      items[cursor].scrollIntoView({ block: 'nearest' });
    };

    const open = async () => {
      if (dialog.open) return;
      dialog.showModal();
      input.value = '';
      render('');
      input.focus();
      await loadIndex();
      if (input.value) render(input.value);
    };

    openPalette = open;

    // The search buttons live in the topbar, which is rebuilt each page — rebind them.
    document.querySelectorAll('[data-search-open]').forEach((b) => b.addEventListener('click', open));

    let t: ReturnType<typeof setTimeout>;
    input.addEventListener('input', async () => {
      clearTimeout(t);
      const v = input.value;
      await loadIndex();
      t = setTimeout(() => render(v), 60);
    });

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        dialog.close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        select(cursor + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        select(cursor - 1);
      } else if (e.key === 'Enter') {
        const el = items[cursor] as HTMLAnchorElement | undefined;
        if (el) {
          e.preventDefault();
          dialog.close();
          // Click it rather than assigning location, so the router handles the
          // navigation like any other link instead of forcing a full reload.
          el.click();
        }
      }
    });

    // Click on the backdrop closes.
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  };

  // Bound once: the shortcut is global and must survive every navigation.
  if (!keysBound) {
    keysBound = true;
    document.addEventListener('keydown', (e) => {
      const dialog = liveDialog;
      if (!dialog) return;
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (dialog.open) dialog.close();
        else openPalette();
        return;
      }
      const target = e.target as HTMLElement;
      const typing = /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName) || target.isContentEditable;
      if (e.key === '/' && !dialog.open && !typing) {
        e.preventDefault();
        openPalette();
      }
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
