---
import BaseLayout from '@layouts/BaseLayout.astro';
import SpectrumBar from '@components/SpectrumBar.astro';
import { getBanks, getStats } from '@lib/content.ts';
import { GROUP_ORDER, SECTIONS } from '@lib/sections.ts';
import { url, GITHUB_URL } from '@lib/url.ts';

const stats = getStats();
const banks = getBanks();
const n = (v: number) => v.toLocaleString();
---

<BaseLayout
  title="Frontend Interview Prep"
  description={`${n(stats.questions)} frontend interview questions across ${stats.sections} topics — ranked by difficulty, mapped to the best resource. Free and open source.`}
  bare
>
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Open-source frontend interview handbook</p>

      <h1>
        Walk in knowing you<br />
        <em>didn't miss anything.</em>
      </h1>

      <p class="lede">
        {n(stats.questions)} questions across {stats.sections} topics — each one ranked by difficulty and pointed at the
        single best place to learn it.
      </p>

      <div class="corpus">
        <div class="corpus-head">
          <span class="eyebrow">The whole corpus</span>
          <span class="mono corpus-n">{n(stats.questions)} questions</span>
        </div>
        <SpectrumBar counts={stats.counts} size="lg" labels animate />
      </div>

      <div class="cta">
        <a class="btn btn-primary" href={url('roadmap/')}>Start with the roadmap</a>
        <a class="btn" href={url('banks/')}>Browse question banks</a>
      </div>

      <ul class="stat-strip mono">
        <li><b>{stats.sections}</b> sections</li>
        <li><b>{stats.categories}</b> categories</li>
        <li><b>{stats.deepDives}</b> worked deep-dives</li>
        <li><b>{stats.companyGuides}</b> company guides</li>
      </ul>
    </div>
  </section>

  <section class="band">
    <div class="band-inner">
      <header class="band-head">
        <div>
          <p class="eyebrow">Question banks</p>
          <h2>Every question, bucketed by what it tests</h2>
        </div>
        <a class="more" href={url('banks/')}>All banks →</a>
      </header>

      <ul class="bank-grid">
        {
          banks.map((b) => (
            <li>
              <a class="bank-card" href={url(`banks/${b.slug}/`)}>
                <div class="bc-top">
                  <span class="bc-emoji" aria-hidden="true">
                    {b.emoji}
                  </span>
                  <span class="bc-n mono">{n(b.counts.total)}</span>
                </div>
                <h3>{b.title}</h3>
                <p>{b.blurb}</p>
                <SpectrumBar counts={b.counts} size="sm" class="bc-bar" />
                <p class="bc-meta mono">
                  {b.categories.length} categories
                  <span class="bc-arrow">→</span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="band band-alt">
    <div class="band-inner">
      <header class="band-head">
        <div>
          <p class="eyebrow">The handbook</p>
          <h2>{stats.sections} sections, ordered the way you should learn them</h2>
        </div>
        <a class="more" href={url('sections/')}>All sections →</a>
      </header>

      <div class="groups">
        {
          GROUP_ORDER.map((group) => (
            <div class="group">
              <p class="eyebrow g-name">{group}</p>
              <ul class="sec-list">
                {SECTIONS.filter((s) => s.group === group).map((s) => (
                  <li>
                    <a href={url(`sections/${s.slug}/`)}>
                      <span class="s-num mono">{s.num}</span>
                      <span class="s-body">
                        <span class="s-title">{s.title}</span>
                        <span class="s-blurb">{s.blurb}</span>
                      </span>
                      {s.bank && <span class="s-bank mono">bank</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="band">
    <div class="band-inner closing">
      <h2>It's a repo, not a course.</h2>
      <p>
        Everything here is Markdown on GitHub — this site is generated from it. Found a missing question or a better
        resource? Open a pull request.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">Star on GitHub</a>
        <a class="btn" href={url('faq/')}>Read the FAQ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero --------------------------------------------------------------- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -240px;
    left: 50%;
    translate: -50% 0;
    width: 900px;
    height: 520px;
    background: radial-gradient(closest-side, var(--accent-glow), transparent 72%);
    opacity: 0.5;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 92px 24px 80px;
    text-align: center;
  }

  .hero h1 {
    font-size: var(--step-4);
    font-weight: 600;
    margin: 18px 0 0;
    letter-spacing: -0.035em;
  }
  .hero h1 em {
    font-style: normal;
    color: var(--text-dim);
  }

  .lede {
    max-width: 620px;
    margin: 20px auto 0;
    color: var(--text-dim);
    font-size: var(--step-1);
    line-height: 1.55;
  }

  .corpus {
    margin: 52px auto 0;
    max-width: 720px;
    text-align: left;
    padding: 20px 22px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
  }
  .corpus-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
  }
  .corpus-n {
    font-size: var(--step--1);
    color: var(--text);
    font-weight: 500;
  }

  .cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 36px;
  }

  .stat-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px 28px;
    list-style: none;
    margin: 42px 0 0;
    padding: 0;
    font-size: var(--step--1);
    color: var(--text-faint);
  }
  .stat-strip b {
    color: var(--text);
    font-weight: 500;
  }

  /* Buttons ------------------------------------------------------------ */
  .btn {
    display: inline-flex;
    align-items: center;
    height: 42px;
    padding: 0 20px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text);
    font-size: var(--step--1);
    font-weight: 500;
    text-decoration: none;
    transition:
      transform 0.14s var(--ease),
      border-color 0.14s var(--ease),
      background 0.14s var(--ease);
  }
  .btn:hover {
    transform: translateY(-1px);
    border-color: var(--text-faint);
    color: var(--text);
  }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-contrast);
    box-shadow: 0 6px 28px -8px var(--accent-glow);
  }
  .btn-primary:hover {
    background: var(--accent-hi);
    border-color: var(--accent-hi);
    color: var(--accent-contrast);
  }

  /* Bands -------------------------------------------------------------- */
  .band {
    padding: 76px 24px;
  }
  .band-alt {
    background: var(--bg-elev);
    border-block: 1px solid var(--border);
  }
  .band-inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .band-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 36px;
  }
  .band-head .eyebrow {
    margin: 0 0 10px;
  }
  .band-head h2 {
    font-size: var(--step-2);
    margin: 0;
    max-width: 26ch;
  }
  .more {
    color: var(--text-dim);
    text-decoration: none;
    font-size: var(--step--1);
    white-space: nowrap;
  }
  .more:hover {
    color: var(--accent);
  }

  /* Bank cards --------------------------------------------------------- */
  .bank-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(232px, 1fr));
    gap: 16px;
  }

  .bank-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.16s var(--ease),
      border-color 0.16s var(--ease),
      box-shadow 0.16s var(--ease);
  }
  .bank-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-line);
    box-shadow: var(--shadow-md);
  }

  .bc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .bc-emoji {
    font-size: 20px;
  }
  .bc-n {
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .bank-card h3 {
    font-size: var(--step-0);
    margin: 0 0 6px;
    color: var(--text);
  }
  .bank-card p {
    margin: 0;
    font-size: var(--step--1);
    color: var(--text-dim);
    line-height: 1.5;
  }

  .bank-card :global(.bc-bar) {
    margin: 18px 0 12px;
  }

  .bc-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto !important;
    font-size: 11px;
    color: var(--text-faint) !important;
  }
  .bc-arrow {
    color: var(--text-faint);
    transition: translate 0.16s var(--ease), color 0.16s var(--ease);
  }
  .bank-card:hover .bc-arrow {
    translate: 3px 0;
    color: var(--accent);
  }

  /* Section groups ----------------------------------------------------- */
  .groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 34px 30px;
  }
  .g-name {
    margin: 0 0 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .sec-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sec-list a {
    display: flex;
    gap: 12px;
    align-items: baseline;
    padding: 9px 10px 9px 6px;
    border-radius: var(--r-md);
    text-decoration: none;
    color: inherit;
    transition: background 0.13s var(--ease);
  }
  .sec-list a:hover {
    background: var(--surface);
  }
  .s-num {
    font-size: 10px;
    color: var(--text-faint);
    flex: none;
  }
  .s-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }
  .s-title {
    color: var(--text);
    font-size: var(--step--1);
    font-weight: 500;
  }
  .sec-list a:hover .s-title {
    color: var(--accent);
  }
  .s-blurb {
    color: var(--text-faint);
    font-size: 11.5px;
    line-height: 1.45;
  }
  .s-bank {
    flex: none;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 2px 6px;
    border-radius: 999px;
    align-self: center;
  }

  /* Closing ------------------------------------------------------------ */
  .closing {
    text-align: center;
    max-width: 560px;
  }
  .closing h2 {
    font-size: var(--step-2);
  }
  .closing p {
    color: var(--text-dim);
    margin: 14px 0 0;
  }

  @media (max-width: 640px) {
    .hero-inner {
      padding: 64px 18px 56px;
    }
    .band {
      padding: 56px 18px;
    }
    .band-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
