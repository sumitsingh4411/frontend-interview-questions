---
import BaseLayout from '@layouts/BaseLayout.astro';
import SpectrumBar from '@components/SpectrumBar.astro';
import { getBanks, getStats } from '@lib/content.ts';
import { GROUP_ORDER, SECTIONS } from '@lib/sections.ts';
import { url, GITHUB_URL } from '@lib/url.ts';

const stats = getStats();
const banks = getBanks();
const n = (v: number) => v.toLocaleString();

// The headline's underline is the spectrum at its true proportions.
const t = stats.counts.total || 1;
const stopEasy = (stats.counts.easy / t) * 100;
const stopMed = stopEasy + (stats.counts.medium / t) * 100;
---

<BaseLayout
  title="Frontend Interview Prep"
  description={`${n(stats.questions)} frontend interview questions across ${stats.sections} topics — ranked by difficulty, mapped to the best resource. Free and open source.`}
  bare
>
  <section class="hero">
    <div class="hero-inner">
      <p class="pill">
        <span class="pill-dot" aria-hidden="true"></span>
        Open source · MIT · generated from Markdown
      </p>

      <h1>
        <span class="quiet">Walk in knowing you</span>
        <span class="punch" style={`--stop-e:${stopEasy}%;--stop-m:${stopMed}%`}>didn't miss anything.</span>
      </h1>

      <p class="lede">
        {n(stats.questions)} questions across {stats.sections} topics — each one ranked by difficulty and pointed at the
        single best place to learn it.
      </p>

      <div class="corpus">
        <div class="corpus-head">
          <span class="eyebrow">The whole corpus</span>
          <span class="mono corpus-n">{n(stats.questions)} questions</span>
        </div>
        <SpectrumBar counts={stats.counts} size="lg" labels animate />
      </div>

      <div class="cta">
        <a class="btn btn-primary" href={url('roadmap/')}>
          Start with the roadmap
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn" href={url('banks/')}>Browse question banks</a>
      </div>

      <ul class="stat-strip">
        <li><b class="mono">{stats.sections}</b><span>sections</span></li>
        <li><b class="mono">{stats.categories}</b><span>categories</span></li>
        <li><b class="mono">{stats.deepDives}</b><span>worked deep-dives</span></li>
        <li><b class="mono">{stats.companyGuides}</b><span>company guides</span></li>
      </ul>
    </div>
  </section>

  <section class="band">
    <div class="band-inner">
      <header class="band-head">
        <p class="eyebrow">Question banks</p>
        <h2>Every question, bucketed by what it tests</h2>
      </header>

      <ul class="bank-grid">
        {
          banks.map((b) => (
            <li>
              <a class="bank-card" href={url(`banks/${b.slug}/`)}>
                <span class="edge-lit" aria-hidden="true" />
                <div class="bc-top">
                  <span class="bc-tile" aria-hidden="true">
                    {b.emoji}
                  </span>
                  <span class="bc-count">
                    <b class="mono">{n(b.counts.total)}</b>
                    <i>questions</i>
                  </span>
                </div>

                <h3>{b.title}</h3>
                <p class="bc-blurb">{b.blurb}</p>

                <SpectrumBar counts={b.counts} size="sm" class="bc-bar" />

                <div class="bc-foot mono">
                  <span>{b.categories.length} categories</span>
                  <span class="bc-arrow" aria-hidden="true">
                    →
                  </span>
                </div>
              </a>
            </li>
          ))
        }

        <li>
          <a class="bank-card is-all" href={url('banks/')}>
            <span class="edge-lit" aria-hidden="true"></span>
            <div class="bc-top">
              <span class="bc-tile is-ghost" aria-hidden="true">✦</span>
              <span class="bc-count">
                <b class="mono">{n(stats.questions)}</b>
                <i>in total</i>
              </span>
            </div>

            <h3>All question banks</h3>
            <p class="bc-blurb">Every bank in one place, {stats.categories} categories deep. Filter, search, and track what you finish.</p>

            <SpectrumBar counts={stats.counts} size="sm" class="bc-bar" />

            <div class="bc-foot mono">
              <span>Browse all</span>
              <span class="bc-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="band band-alt">
    <div class="band-inner">
      <header class="band-head">
        <div class="head-row">
          <p class="eyebrow">The handbook</p>
          <a class="more" href={url('sections/')}>All sections <span aria-hidden="true">→</span></a>
        </div>
        <h2>{stats.sections} sections, ordered the way you should learn them</h2>
      </header>

      {
        GROUP_ORDER.map((group, gi) => {
          const rows = SECTIONS.filter((s) => s.group === group);
          return (
            <>
              {/* The numbering is real: these are stages you work through in order. */}
              <div class="stage-row">
                <span class="stage-num mono">{String(gi + 1).padStart(2, '0')}</span>
                <h3 class="eyebrow stage-name">{group}</h3>
                <span class="rule" aria-hidden="true" />
                <span class="stage-count mono">
                  {rows.length} sections
                </span>
              </div>

              <ul class="sec-grid">
                {rows.map((s) => (
                  <li>
                    <a class="sec-card" href={url(`sections/${s.slug}/`)}>
                      <span class="edge-lit" aria-hidden="true" />
                      <span class="sc-top">
                        <span class="sc-emoji" aria-hidden="true">
                          {s.emoji}
                        </span>
                        <span class="sc-meta">
                          {s.bank && <span class="s-bank mono">bank</span>}
                          <span class="sc-num mono">{s.num}</span>
                        </span>
                      </span>
                      <h4>{s.title}</h4>
                      <p>{s.blurb}</p>
                    </a>
                  </li>
                ))}
              </ul>
            </>
          );
        })
      }
    </div>
  </section>

  <section class="band">
    <div class="band-inner closing">
      <h2>It's a repo, not a course.</h2>
      <p>
        Everything here is Markdown on GitHub — this site is generated from it. Found a missing question or a better
        resource? Open a pull request.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
          Star on GitHub
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <a class="btn" href={url('faq/')}>Read the FAQ</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero --------------------------------------------------------------- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  /* Spotlight */
  .hero::before {
    content: '';
    position: absolute;
    top: -280px;
    left: 50%;
    translate: -50% 0;
    width: 1000px;
    height: 600px;
    background: radial-gradient(closest-side, var(--accent-glow), transparent 72%);
    opacity: 0.55;
    pointer-events: none;
  }

  /* Faint dot grid, faded out toward the edges */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle at 1px 1px, var(--border-strong) 1px, transparent 0);
    background-size: 30px 30px;
    opacity: 0.3;
    -webkit-mask-image: radial-gradient(ellipse 78% 62% at 50% 4%, #000 35%, transparent 78%);
    mask-image: radial-gradient(ellipse 78% 62% at 50% 4%, #000 35%, transparent 78%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 920px;
    margin: 0 auto;
    padding: 88px 24px 84px;
    text-align: center;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin: 0;
    padding: 6px 14px 6px 11px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    backdrop-filter: blur(6px);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-dim);
  }
  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--easy);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--easy) 70%, transparent);
    animation: ping 2.4s var(--ease) infinite;
  }
  @keyframes ping {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--easy) 60%, transparent);
    }
    70%,
    100% {
      box-shadow: 0 0 0 7px transparent;
    }
  }

  .hero h1 {
    display: flex;
    flex-direction: column;
    /* shrink each line to its text so the underline hugs the punchline */
    align-items: center;
    gap: 0.04em;
    font-size: var(--step-4);
    font-weight: 600;
    letter-spacing: -0.038em;
    margin: 22px 0 0;
  }
  .quiet {
    color: var(--text-dim);
  }

  /* The punchline is underscored by the corpus's real difficulty split. */
  .punch {
    position: relative;
    display: inline-block;
    color: var(--text);
    padding-bottom: 0.1em;
  }
  .punch::after {
    content: '';
    position: absolute;
    left: 0.02em;
    right: 0.02em;
    bottom: 0;
    height: 5px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--easy) 0 var(--stop-e),
      var(--medium) var(--stop-e) var(--stop-m),
      var(--hard) var(--stop-m) 100%
    );
    transform-origin: left center;
    animation: sweep 0.95s var(--ease) 0.3s both;
  }
  @keyframes sweep {
    from {
      transform: scaleX(0);
      opacity: 0;
    }
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  .lede {
    max-width: 620px;
    margin: 26px auto 0;
    color: var(--text-dim);
    font-size: var(--step-1);
    line-height: 1.55;
  }

  .corpus {
    margin: 50px auto 0;
    max-width: 720px;
    text-align: left;
    padding: 20px 22px 18px;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-md);
  }
  .corpus-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 14px;
  }
  .corpus-n {
    font-size: var(--step--1);
    color: var(--text);
    font-weight: 500;
  }

  .cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 36px;
  }

  .stat-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 30px;
    list-style: none;
    margin: 44px 0 0;
    padding: 0;
  }
  .stat-strip li {
    display: flex;
    align-items: baseline;
    gap: 7px;
  }
  .stat-strip b {
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .stat-strip span {
    font-size: var(--step--1);
    color: var(--text-faint);
  }

  /* Buttons ------------------------------------------------------------ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 44px;
    padding: 0 22px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text);
    font-size: var(--step--1);
    font-weight: 500;
    text-decoration: none;
    transition:
      transform 0.14s var(--ease),
      border-color 0.14s var(--ease),
      background 0.14s var(--ease);
  }
  .btn:hover {
    transform: translateY(-1px);
    border-color: var(--text-faint);
    color: var(--text);
  }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-contrast);
    box-shadow: 0 8px 30px -8px var(--accent-glow);
  }
  .btn-primary:hover {
    background: var(--accent-hi);
    border-color: var(--accent-hi);
    color: var(--accent-contrast);
    box-shadow: 0 12px 36px -8px var(--accent-glow);
  }
  .btn-arrow {
    transition: translate 0.16s var(--ease);
  }
  .btn:hover .btn-arrow {
    translate: 3px 0;
  }

  /* Bands -------------------------------------------------------------- */
  .band {
    padding: 84px 24px;
  }
  .band-alt {
    background: var(--bg-elev);
    border-block: 1px solid var(--border);
  }
  .band-inner {
    max-width: 1180px;
    margin: 0 auto;
  }

  .band-head {
    margin-bottom: 38px;
  }
  .band-head .eyebrow {
    margin: 0 0 10px;
  }
  .band-head h2 {
    font-size: var(--step-2);
    margin: 0;
    max-width: 26ch;
  }
  /* Keep the "all sections" link on the eyebrow line — anchoring it to a
     two-line heading's baseline left it floating. */
  .head-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 10px;
  }
  .head-row .eyebrow {
    margin: 0;
  }
  .more {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: var(--step--1);
    white-space: nowrap;
  }
  .more span {
    transition: translate 0.16s var(--ease);
  }
  .more:hover {
    color: var(--accent);
  }
  .more:hover span {
    translate: 3px 0;
  }

  /* Bank cards --------------------------------------------------------- */
  /* Five banks + one "all banks" cell = a clean 3x2. No orphan row. */
  .bank-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .bank-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 22px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition:
      transform 0.18s var(--ease),
      border-color 0.18s var(--ease),
      box-shadow 0.18s var(--ease);
  }
  .bank-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-line);
    box-shadow: var(--shadow-md);
  }

  /* A hairline of accent that sweeps across the top edge on hover. */
  .edge-lit {
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.22s var(--ease);
  }
  .bank-card:hover .edge-lit {
    opacity: 1;
  }

  .bc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }
  .bc-tile {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    font-size: 18px;
    border-radius: var(--r-md);
    border: 1px solid var(--border);
    background: linear-gradient(160deg, var(--surface-2), var(--surface));
  }
  .bc-tile.is-ghost {
    color: var(--accent);
    border-color: var(--accent-line);
    background: var(--accent-dim);
  }

  .bc-count {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    line-height: 1.1;
  }
  .bc-count b {
    font-size: var(--step-2);
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.03em;
  }
  .bc-count i {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-faint);
    margin-top: 3px;
  }

  .bank-card h3 {
    font-size: var(--step-1);
    margin: 0 0 7px;
    color: var(--text);
  }
  .bank-card:hover h3 {
    color: var(--accent);
  }
  .bc-blurb {
    margin: 0;
    font-size: var(--step--1);
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* Pin the bar to the bottom so it lines up across a row, whatever the
     blurb's line count. */
  .bank-card :global(.bc-bar) {
    margin-top: auto;
    padding-top: 22px;
    margin-bottom: 14px;
  }

  .bc-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2px;
    font-size: 11px;
    color: var(--text-faint);
  }
  .bc-arrow {
    transition:
      translate 0.16s var(--ease),
      color 0.16s var(--ease);
  }
  .bank-card:hover .bc-arrow {
    translate: 3px 0;
    color: var(--accent);
  }

  .is-all {
    background: linear-gradient(160deg, color-mix(in srgb, var(--accent-dim) 70%, var(--surface)), var(--surface));
    border-color: var(--accent-line);
  }

  /* Stages -------------------------------------------------------------
     Four columns grouped by stage left a ragged bottom edge (5 / 3 / 8 / 5).
     Instead: a labelled rule per stage, with cards flowing under it. */
  .stage-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 44px 0 18px;
  }
  .stage-row:first-of-type {
    margin-top: 0;
  }
  .stage-num {
    flex: none;
    font-size: 10px;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid var(--accent-line);
    padding: 3px 7px;
    border-radius: 6px;
  }
  .stage-name {
    margin: 0;
    flex: none;
  }
  .rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }
  .stage-count {
    flex: none;
    font-size: 10px;
    color: var(--text-faint);
  }

  /* Five columns is deliberate: Core (5) and Interview prep (5) land as exact
     rows, and Engineering (8) breaks 5 + 3 — no lone trailing card. */
  .sec-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .sec-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 16px 16px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition:
      transform 0.16s var(--ease),
      border-color 0.16s var(--ease);
  }
  .sec-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-line);
  }
  .sec-card:hover .edge-lit {
    opacity: 1;
  }

  .sc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 13px;
  }
  .sc-emoji {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    font-size: 15px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: linear-gradient(160deg, var(--surface-2), var(--surface));
  }
  /* Pill lives up here with the number, so cards need no footer and gain
     no dead space when a section has no bank. */
  .sc-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sc-num {
    font-size: 10px;
    color: var(--text-faint);
  }

  .sec-card h4 {
    margin: 0 0 6px;
    font-family: var(--font-display);
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.015em;
  }
  .sec-card:hover h4 {
    color: var(--accent);
  }
  /* 3 lines: at five columns every blurb fits whole, so nothing truncates
     mid-word. The clamp stays as a guard for future, longer blurbs. */
  .sec-card p {
    margin: 0;
    font-size: 11.5px;
    line-height: 1.5;
    color: var(--text-faint);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .s-bank {
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid var(--accent-line);
    padding: 2px 7px;
    border-radius: 999px;
    white-space: nowrap;
  }

  /* Closing ------------------------------------------------------------ */
  .closing {
    text-align: center;
    max-width: 560px;
  }
  .closing h2 {
    font-size: var(--step-2);
  }
  .closing p {
    color: var(--text-dim);
    margin: 14px 0 0;
  }

  @media (max-width: 1140px) {
    .sec-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 960px) {
    .bank-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .sec-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .sec-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hero-inner {
      padding: 60px 18px 56px;
    }
    .hero h1 {
      letter-spacing: -0.03em;
    }
    .band {
      padding: 56px 18px;
    }
    .band-head-row {
      flex-direction: column;
      align-items: flex-start;
    }
    .bank-grid {
      grid-template-columns: minmax(0, 1fr);
    }
    .sec-grid {
      grid-template-columns: minmax(0, 1fr);
    }
    .stage-row {
      margin: 34px 0 14px;
    }
    .stage-count {
      display: none;
    }
    .stat-strip {
      gap: 10px 22px;
    }
  }
</style>
